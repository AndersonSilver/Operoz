# API URL (local Docker: port 8000). OAuth flags come from GET /api/instances/ on this host.
VITE_API_BASE_URL="http://localhost:8000"
# Chat SSE dedicado (api-chat). Ver docs/assistant-scaling.md
VITE_ASSISTANT_CHAT_API_URL="http://localhost:8001"
# Fila Celery async (POST 202 + stream do job). Requer assistant-chat-worker.
VITE_ASSISTANT_ASYNC_CHAT="1"

VITE_WEB_BASE_URL="http://localhost:3000"

VITE_ADMIN_BASE_URL="http://localhost:3001"
VITE_ADMIN_BASE_PATH="/god-mode"

VITE_SPACE_BASE_URL="http://localhost:3002"
VITE_SPACE_BASE_PATH="/spaces"

VITE_LIVE_BASE_URL="http://localhost:3100"
VITE_LIVE_BASE_PATH="/live"

# Boards sidebar (Tech4Humans): set to "true" for mock hierarchy (Etapa 2+)
VITE_ENABLE_BOARDS="true"
