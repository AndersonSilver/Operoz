# Backend
# Debug value for api server use it as 0 for production use
DEBUG=0
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3100,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,http://127.0.0.1:3100"

# Database Settings
POSTGRES_USER="operis"
POSTGRES_PASSWORD="operis"
POSTGRES_HOST="operis-db"
POSTGRES_DB="operis"
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Settings
REDIS_HOST="operis-redis"
REDIS_PORT="6379"
REDIS_URL="redis://${REDIS_HOST}:6379/"

# RabbitMQ Settings
RABBITMQ_HOST="operis-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="operis"
RABBITMQ_PASSWORD="operis"
RABBITMQ_VHOST="operis"

# AWS Settings
AWS_REGION=""
AWS_ACCESS_KEY_ID="access-key"
AWS_SECRET_ACCESS_KEY="secret-key"
AWS_S3_ENDPOINT_URL="http://localhost:9000"
# Browser-reachable MinIO URL for presigned uploads when the API is not behind /uploads reverse proxy
# (e.g. docker-compose-local: set to http://localhost:9000). Leave empty when nginx proxies /uploads on WEB_URL.
MINIO_PUBLIC_ENDPOINT_URL=""
# Changing this requires change in the proxy config for uploads if using minio setup
AWS_S3_BUCKET_NAME="uploads"
# Maximum file upload limit
FILE_SIZE_LIMIT=5242880
# Signed URL expiration time in seconds (default: 3600 = 1 hour)
# Set to 30 for 30 seconds, 300 for 5 minutes, etc.
SIGNED_URL_EXPIRATION=3600

# Settings related to Docker
DOCKERIZED=1 # deprecated

# set to 1 If using the pre-configured minio setup
USE_MINIO=0



# Public API origin (emails, OAuth callbacks, /api/* from browser when split from SPA).
# Local dev with separate ports: API on :8000. Production behind proxy: same as WEB_URL / public domain.
WEB_URL="http://localhost:8000"

# Gunicorn Workers
GUNICORN_WORKERS=2
# Serviço api-chat dedicado (SSE / assistente) — ver docs/assistant-scaling.md
GUNICORN_CHAT_WORKERS=8
GUNICORN_CHAT_TIMEOUT=120
# PgBouncer: 1 = POSTGRES_HOST deve apontar para operis-pgbouncer
USE_PGBOUNCER=0
# POSTGRES_HOST=operis-pgbouncer
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@operis-pgbouncer:5432/${POSTGRES_DB}

# Base URLs
ADMIN_BASE_URL="http://localhost:3001"
ADMIN_BASE_PATH="/god-mode"

SPACE_BASE_URL="http://localhost:3002"
SPACE_BASE_PATH="/spaces"

# Main SPA (guest links, auth redirects). Local dev: :3000. Production: public app URL (often same as WEB_URL).
APP_BASE_URL="http://localhost:3000"
APP_BASE_PATH=""

LIVE_BASE_URL="http://localhost:3100"
LIVE_BASE_PATH="/live"

LIVE_SERVER_SECRET_KEY="secret-key"

# Hard delete files after days
HARD_DELETE_AFTER_DAYS=60

# Force HTTPS for handling SSL Termination
MINIO_ENDPOINT_SSL=0

# API key rate limit
API_KEY_RATE_LIMIT="60/minute"

# Assistente Operoz (ver docs/assistant-env.md)
LLM_API_KEY=""
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"
LLM_BASE_URL=""
ASSISTANT_ENABLED="1"
ASSISTANT_CELERY_QUEUE="assistant"
ASSISTANT_CHAT_CELERY_QUEUE="assistant-chat"
ASSISTANT_WORKER_CONCURRENCY="2"
ASSISTANT_CHAT_WORKER_CONCURRENCY="8"
# 1 = POST /chat/ com stream enfileira job (202) em vez de SSE inline
ASSISTANT_ASYNC_CHAT_DEFAULT="0"
ASSISTANT_MAX_MESSAGES_PER_USER_PER_HOUR="60"
ASSISTANT_MAX_MESSAGES_PER_WORKSPACE_PER_HOUR="500"
ASSISTANT_DAILY_TOKEN_BUDGET="200000"
ASSISTANT_EMBEDDING_MODEL="text-embedding-3-small"
ASSISTANT_RAG_QUERY_EMBEDDING_CACHE_TTL="600"
ASSISTANT_RAG_RESULTS_CACHE_TTL="180"
ASSISTANT_RAG_HNSW_EF_SEARCH="40"
ASSISTANT_SUMMARY_SYNC="0"
ASSISTANT_DEFER_NONCRITICAL="1"
ASSISTANT_MAX_CONCURRENT_LLM="40"
ASSISTANT_MAX_ACTIVE_CHATS_PER_USER="2"
LLM_MODEL_FALLBACK="gpt-4o-mini"
# LLM_API_KEYS="sk-a,sk-b"
ASSISTANT_METRICS_TOKEN=""
ASSISTANT_CHAT_QUEUE_ALERT_THRESHOLD="100"
CELERY_QUEUE_ALERT_THRESHOLD="500"
