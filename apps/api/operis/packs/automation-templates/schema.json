{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OperozAutomationTemplate",
  "type": "object",
  "required": ["id", "version", "name", "description", "graph", "parameters"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "icon": { "type": "string" },
    "category": { "type": "string" },
    "default_rule_name": { "type": "string" },
    "default_description": { "type": "string" },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "type", "label"],
        "properties": {
          "key": { "type": "string" },
          "type": { "type": "string" },
          "label": { "type": "string" },
          "default": {},
          "required": { "type": "boolean" }
        }
      }
    },
    "graph": { "type": "object" }
  }
}
