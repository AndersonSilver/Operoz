{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operis.local/schemas/automation-pack.json",
  "title": "Operoz Automation Pack",
  "type": "object",
  "required": ["name", "version", "description", "permissions"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string", "minLength": 1 },
    "permissions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "hooks": { "type": "string" },
    "playbooks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "catalog": {
      "type": "array",
      "items": { "$ref": "#/$defs/catalogEntry" }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/packRule" }
    }
  },
  "$defs": {
    "catalogEntry": {
      "type": "object",
      "required": ["key", "kind", "label", "handler_ref"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{2,127}$" },
        "kind": { "enum": ["trigger", "filter", "action", "decision", "parallel"] },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "handler_ref": { "type": "string" },
        "config_schema": { "type": "object" },
        "output_schema": { "type": "object" }
      }
    },
    "packRule": {
      "type": "object",
      "required": ["template_id"],
      "additionalProperties": false,
      "properties": {
        "template_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "parameters": { "type": "object" },
        "publish": { "type": "boolean" }
      }
    }
  }
}
