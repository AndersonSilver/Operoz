# Base URL da API Operis (sem barra final)
OPERIS_API_BASE_URL=http://localhost:8000

# Token de API (God mode / Definições → API tokens). Cobre /api/v1/*
OPERIS_API_KEY=

# Opcional: sessão para /api/* (boards, issues web). Preenchido por operis_sign_in ou manualmente:
# OPERIS_SESSION_COOKIE=sessionid=...
