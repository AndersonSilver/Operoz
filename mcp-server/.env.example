# Base URL da API Operoz (sem barra final)
OPEROZ_API_BASE_URL=http://localhost:8000

# Token de API (God mode / Definições → API tokens). Cobre /api/v1/* e /api/* (boards, Cliente 360, etc.)
OPEROZ_API_KEY=

# Perfil MCP: agent (default, 7 tools — discover+execute) | full (676 tools, 1 por endpoint)
OPEROZ_MCP_PROFILE=agent

# Legado: só necessário se preferires autenticar /api/* por sessão em vez de OPEROZ_API_KEY.
# Preenchido por operoz_sign_in ou manualmente:
# OPEROZ_SESSION_COOKIE=sessionid=...
