# Copie para operoz-mcp-hml.env na VPS (não commitar tokens):
#   cp operoz-mcp-hml.env.example operoz-mcp-hml.env

# URL da API de HML (usada pelo MCP para chamar a API) — nunca operoz.io aqui.
OPEROZ_API_BASE_URL=https://hml.operoz.io

# Imagem após deploy (GHCR → tag local)
MCP_IMAGE=myoperoz/operoz-mcp:hml

# Host permitido no header Host (proteção DNS rebinding do SDK MCP)
MCP_ALLOWED_HOSTS=mcp-hml.operoz.io,127.0.0.1,localhost

# Publicação no host. Ajuste conforme o NPM alcançar a porta (host networking
# no Contabo usa 127.0.0.1; um NPM em bridge network precisaria de 0.0.0.0).
MCP_PUBLISH=127.0.0.1:3101

# OPEROZ_API_KEY não vai aqui — cada utilizador envia o token no Cursor (header Authorization).
