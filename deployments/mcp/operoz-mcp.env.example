# Copie para operoz-mcp.env na VPS (não commitar tokens):
#   cp operoz-mcp.env.example operoz-mcp.env

# URL pública da API Operoz (usada pelo MCP para chamar a API)
OPEROZ_API_BASE_URL=https://operoz.io

# Imagem após deploy (GHCR → tag local)
MCP_IMAGE=myoperoz/operoz-mcp:stable

# Host permitido no header Host (proteção DNS rebinding do SDK MCP)
MCP_ALLOWED_HOSTS=mcp.operoz.io,127.0.0.1,localhost

# Publicação no host. NPM (Docker) precisa alcançar a porta — use 0.0.0.0 (não 127.0.0.1).
MCP_PUBLISH=0.0.0.0:3100

# OPEROZ_API_KEY não vai aqui — cada utilizador envia o token no Cursor (header Authorization).
