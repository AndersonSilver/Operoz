# Copie para operis-mcp.env na VPS (não commitar tokens):
#   cp operis-mcp.env.example operis-mcp.env

# URL pública da API Operis (usada pelo MCP para chamar a API)
OPERIS_API_BASE_URL=https://operis.webcycle.com.br

# Imagem após deploy (GHCR → tag local)
MCP_IMAGE=myoperis/operis-mcp:stable

# Host permitido no header Host (proteção DNS rebinding do SDK MCP)
MCP_ALLOWED_HOSTS=mcp.operis.webcycle.com.br,127.0.0.1,localhost

# Publicação no host. NPM (Docker) precisa alcançar a porta — use 0.0.0.0 (não 127.0.0.1).
MCP_PUBLISH=0.0.0.0:3100

# OPERIS_API_KEY não vai aqui — cada utilizador envia o token no Cursor (header Authorization).
